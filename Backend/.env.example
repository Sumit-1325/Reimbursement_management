# Database URLs (get from Neon Dashboard)
# DATABASE_URL is the pooled connection (for app runtime)
# DIRECT_URL is the direct connection (for migrations)
DATABASE_URL="postgresql://user:password@ep-xxxxx.us-east-1.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxxx.us-east-1.neon.tech/dbname?sslmode=require"

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d


# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

