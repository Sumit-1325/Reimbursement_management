{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "rootDir": "./src",
    "outDir": "./dist",
    "allowJs": true,
    "checkJs": false,
    "noEmit": false,
    "strict": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "dist"]
}