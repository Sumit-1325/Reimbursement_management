{
  "name": "hackathon-backend",
  "version": "1.0.0",
  "description": "Backend for Hackathon Management System",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "build": "npx prisma generate && npx prisma migrate deploy && npx tsc",
    "postinstall": "prisma generate",
    "dev": "nodemon src/index.js",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "hackathon",
    "management",
    "event"
  ],
  "author": "Sumit Kumar",
  "license": "ISC",
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "typescript": "^5.9.3"
  }
}
